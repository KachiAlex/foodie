{
  "buildCommand": "cd hosting && npm run build",
  "outputDirectory": "hosting/dist",
  "installCommand": "npm install && cd hosting && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

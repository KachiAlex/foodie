{
  "name": "foodie-market",
  "version": "1.0.0",
  "description": "Foodie Market — request, bidding & escrow marketplace",
  "private": true,
  "scripts": {
    "dev": "tsx api/index.ts",
    "build": "cd hosting && npm run build",
    "api:dev": "tsx watch api/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "prisma": "^7.6.0",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5"
  }
}

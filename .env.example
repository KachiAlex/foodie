# Backend configuration
# Copy this file to .env and fill in real values. .env.example itself is safe to commit.

# PostgreSQL connection string (e.g., Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@host:5432/foodie?sslmode=require"

# JWT secret used to sign auth tokens (generate a strong random string)
JWT_SECRET="change-me-to-a-long-random-string"

# Paystack secret key (test or live)
PAYSTACK_SECRET_KEY="sk_test_..."

# Cloudinary URL for vendor document uploads
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://key:secret@cloudname"

# Brevo SMTP credentials for sending transactional emails
# Get these from your Brevo account: Settings > SMTP & API > SMTP
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user@smtp-brevo.com"
SMTP_PASS="your-smtp-master-password"
FROM_EMAIL="noreply@foodiemarket.com"
FROM_NAME="Foodie Market"

# Frontend URL used for Paystack callback redirects and password reset links
FRONTEND_URL="http://localhost:5173"

# Optional: port the Express API listens on in development
PORT=3000

# Frontend configuration (place these in hosting/.env when running Vite)
VITE_API_BASE="http://localhost:3000"
